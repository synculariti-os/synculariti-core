{
  "version": 2,
  "outputDirectory": "out",
  "buildCommand": "cd ../.. && pnpm build --filter=@synculariti/web",
  "installCommand": "cd ../.. && pnpm install --ignore-scripts --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "trailingSlash": false
}
